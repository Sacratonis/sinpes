---
import { languages, defaultLang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import { buildFontFaceCSS, sanitizeFontFamily } from '../utils/font';
import { formatTaxonomyLabel, parseUseCases } from '../utils/taxonomy';

interface Props {
  index: number;
  locale?: keyof typeof languages;
  font: any; // Set to 'any' to safely accept the full live R2 JSON object
}

const { index, locale = defaultLang, font } = Astro.props;

const t = useTranslations(locale);
const basePath = locale === defaultLang ? '' : `/${locale}`;

// --- 🧹 BULLETPROOF TAG PARSER & FORMATTER ---
const tags = parseUseCases(font.use_cases).map(formatTaxonomyLabel);
const categoryLabel = formatTaxonomyLabel(font.category || '');
// ---------------------------------------------

const paddedIndex = String(index).padStart(2, '0');

// The real font family name — used in both @font-face and the specimen style
const fontFamily = sanitizeFontFamily(font.display_name);

// The injected @font-face CSS string
const fontFaceCSS = buildFontFaceCSS(font.display_name, font.variants, font.woff2_url);
---

<!-- Real @font-face injected at build time -->
{fontFaceCSS && <style set:html={fontFaceCSS} />}

<div class="font-row font-reveal" role="listitem">
  <!-- Stretched link: entire row navigates to the font page -->
  <a href={`${basePath}/font/${font.slug}`} class="row-link" aria-label={font.display_name}></a>

  <div class="row-index tabular">{paddedIndex}</div>
  
  <div class="row-main">
    <span class="row-name" title={font.display_name}>
      <span class="name-text">{font.display_name}</span>
      {font.is_demo && <span class="row-dot" title="Demo version"></span>}
    </span>
    <div class="row-meta">
      <span>{categoryLabel}</span>
      {tags.map(tag => <span>{tag}</span>)}
    </div>
  </div>
  
  <div class="row-specimen" style={`font-family: "${fontFamily}", 'IBM Plex Sans', sans-serif`}>Ag</div>
  
  <div class="row-actions">
    <a href={`${basePath}/test/${font.slug}`} class="btn btn-test" aria-label={`Test ${font.display_name}`}>
      {t('row.test')}
    </a>
    <a href={`${basePath}/font/${font.slug}`} class="btn btn-get" aria-label={`Download ${font.display_name}`}>
      {t('row.get')}
    </a>
  </div>
</div>

<style>
  .font-row {
    position: relative; /* Required for the stretched link */
    display: grid;
    grid-template-columns: 80px 1fr 120px auto;
    min-height: 96px;
    border-bottom: 0.5px solid var(--rule);
    align-items: center;
    width: 100%;
    transition: background 0.15s;
    cursor: pointer;
  }
  .font-row:hover:not(:has(.btn:hover)) {
    background: color-mix(in srgb, var(--fg) 4%, transparent);
  }

  /* Stretched link covers the whole row but sits behind action buttons */
  .row-link {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .row-actions {
    position: relative;
    z-index: 1;
  }
  .row-specimen {
    position: relative;
    z-index: 1;
  }
  
  .font-reveal {
    opacity: 1;
    transform: translateY(0);
  }

  .row-index {
    font-size: 12px;
    color: var(--muted);
    border-right: 0.5px solid var(--rule);
    height: 100%;
    display: flex;
    align-items: center;
    padding-left: 24px;
  }
  .row-main {
    padding: 14px 24px;
    padding-right: 36px; /* Reserve 12px safe space for hover translation */
    min-width: 0;
  }
  .row-name {
    font-size: 26px;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: var(--fg);
    letter-spacing: -0.01em;
    transition: transform 0.2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .name-text {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .row-dot {
    width: 5px;
    height: 5px;
    background: var(--fg);
    border-radius: 50%;
    flex: 0 0 auto;
  }
  .row-meta {
    margin-top: 4px;
    font-size: 12px;
    color: var(--muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: transform 0.2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .font-row:hover:not(:has(.btn:hover)) .row-name,
  .font-row:hover:not(:has(.btn:hover)) .row-meta {
    transform: translateX(6px);
  }
  .row-meta span::after {
    content: "·";
    margin: 0 6px;
  }
  .row-meta span:last-child::after {
    content: "";
  }
  .row-specimen {
    border-left: 0.5px solid var(--rule);
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 42px;
    color: var(--fg);
    transition: transform 0.2s cubic-bezier(0.22, 1, 0.36, 1);
    overflow: hidden;
    white-space: nowrap;
    text-overflow: clip;
  }
  .font-row:hover:not(:has(.btn:hover)) .row-specimen { transform: scale(1.05); }
  
  .row-actions {
    border-left: 0.5px solid var(--rule);
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 0 24px;
    gap: 12px;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 36px;
    padding: 0 20px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
    cursor: pointer;
    white-space: nowrap;
    border-radius: 0;
    position: relative;
    overflow: hidden;
    z-index: 1;
    transition: color 0.4s cubic-bezier(0.22, 1, 0.36, 1), border-color 0.4s;
  }

  .btn-test {
    border: 0.5px solid var(--rule);
    background: transparent;
    color: var(--fg);
  }
  .btn-test::before {
    content: ""; position: absolute; inset: 0; background: var(--fg); z-index: -1;
    transform: scaleX(0); transform-origin: right;
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .btn-test:hover { color: var(--bg); border-color: var(--fg); }
  .btn-test:hover::before { transform: scaleX(1); transform-origin: left; }

  .btn-get {
    border: 0.5px solid var(--fg);
    background: transparent;
    color: var(--bg);
  }
  .btn-get::before {
    content: ""; position: absolute; inset: 0; background: var(--fg); z-index: -1;
    transform: scaleX(1); transform-origin: right;
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .btn-get:hover { color: var(--fg); }
  .btn-get:hover::before { transform: scaleX(0); transform-origin: left; }

  @media (max-width: 720px) {
    .font-row {
      grid-template-columns: 44px 1fr auto;
      min-height: 80px;
    }
    .row-specimen { display: none; }
    .row-name { font-size: 20px; }
    .row-main { min-width: 0; }
    .name-text { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .row-actions { padding: 0 12px; gap: 8px; }
    .btn { height: 44px; padding: 0 14px; font-size: 10px; }
  }
</style>
