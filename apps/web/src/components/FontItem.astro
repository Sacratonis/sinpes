---
import FontRow from './FontRow.astro';
import FontCard from './FontCard.astro';
import { languages, defaultLang } from '../i18n/ui';
import { parseUseCases } from '../utils/taxonomy';

interface Props {
  index: number;
  locale?: keyof typeof languages;
  font: any;
}

const { index, locale = defaultLang, font } = Astro.props;
const searchValue = [
  font.display_name,
  font.slug,
  font.category,
  ...parseUseCases(font.use_cases),
].filter(Boolean).join(' ');
---

<div
  class="font-item"
  data-font-search={searchValue}
  data-font-name={font.display_name}
  data-font-slug={font.slug}
>
  <div class="font-view-list">
    <FontRow index={index} locale={locale} font={font} />
  </div>
  <div class="font-view-grid">
    <FontCard index={index} locale={locale} font={font} />
  </div>
</div>

<style>
  .font-item {
    content-visibility: auto;
    contain-intrinsic-size: auto 360px;
  }
  :global([data-layout="list"]) .font-item { contain-intrinsic-size: auto 96px; }
  :global([data-layout="poster"]) .font-item { contain-intrinsic-size: auto 460px; }

  /* The layout toggle is controlled globally via data-layout on the documentElement */
  :global([data-layout="grid"]) .font-view-list,
  :global([data-layout="poster"]) .font-view-list {
    display: none;
  }
  :global([data-layout="list"]) .font-view-grid {
    display: none;
  }
</style>
