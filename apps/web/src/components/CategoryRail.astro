---
import { languages, defaultLang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import { categorySlug, formatTaxonomyLabel } from '../utils/taxonomy';

interface Props { 
  locale?: keyof typeof languages; 
  activeCategory?: string;
  categories?: string[]; // Dynamically injected from parent page
}

const { locale = defaultLang, activeCategory = 'all', categories = [] } = Astro.props;
const t = useTranslations(locale);
const basePath = locale === defaultLang ? '' : `/${locale}`;
const categoryTranslations: Record<string, string> = {
  display: t('category.display'),
  historical: t('category.historical'),
  monospaced: t('category.monospaced'),
  'sans-serif': t('category.sansSerif'),
  script: t('category.script'),
};
// Map the dynamic categories
const mappedCategories = [
  { name: t('category.all') || 'All', slug: 'all' },
  ...categories.map(cat => {
    const slug = categorySlug(cat);
    return { name: categoryTranslations[slug] || formatTaxonomyLabel(cat), slug };
  })
];
---

<div class="rail-wrap">
  <div class="rail-anchor">{t('footer.browse') || 'Browse'}</div>
  <nav class="category-rail" id="categoryRail">
    {mappedCategories.map(cat => {
      const isActive = activeCategory === cat.slug;
      const href = cat.slug === 'all' ? `${basePath}/` : `${basePath}/category/${cat.slug}`;
      return (
        <a href={href} class={`cat-cell ${isActive ? 'active' : ''}`}>
          {cat.name}
        </a>
      );
    })}
    <div class="rail-spacer"></div>
  </nav>
  <div class="rail-fade"></div>
  
  <div class="layout-toggle" role="group" aria-label={t('layout.choose')}>
    <button class="layout-btn" type="button" data-layout-choice="list" aria-label={t('layout.list')} title={t('layout.list')}>
      <span aria-hidden="true">≡</span>
    </button>
    <button class="layout-btn" type="button" data-layout-choice="grid" aria-label={t('layout.grid')} title={t('layout.grid')}>
      <span aria-hidden="true">⊞</span>
    </button>
    <button class="layout-btn" type="button" data-layout-choice="poster" aria-label={t('layout.poster')} title={t('layout.poster')}>
      <span aria-hidden="true">▣</span>
    </button>
  </div>
</div>

<style>
  .rail-wrap { position: sticky; top: var(--nav-h, 64px); z-index: 20; border-bottom: 0.5px solid var(--rule); display: flex; align-items: center; justify-content: space-between; background: var(--bg); }
  .rail-anchor {
    flex: 0 0 auto;
    height: 36px;
    display: flex;
    align-items: center;
    padding: 0 20px;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    border-right: 0.5px solid var(--rule);
    white-space: nowrap;
  }
  .category-rail { display: flex; overflow-x: auto; scrollbar-width: none; flex: 1; min-width: 0; }
  .category-rail::-webkit-scrollbar { display: none; }
  .cat-cell { flex: 0 0 auto; padding: 0 18px; height: 36px; display: flex; align-items: center; border-right: 0.5px solid var(--rule); text-transform: uppercase; letter-spacing: .08em; font-size: 10px; color: var(--muted); white-space: nowrap; text-decoration: none; transition: color 0.15s; position: relative; overflow: hidden; }
  .cat-cell::before, .cat-cell::after { position: absolute; top: 50%; opacity: 0; font-size: 10px; font-weight: 500; transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.3s; pointer-events: none; }
  .cat-cell::before { content: '['; left: 8px; transform: translate(-10px, -50%); }
  .cat-cell::after { content: ']'; right: 8px; transform: translate(10px, -50%); }
  .cat-cell:not(.active):hover { color: var(--fg); }
  .cat-cell:not(.active):hover::before { opacity: 1; transform: translate(0, -50%); }
  .cat-cell:not(.active):hover::after { opacity: 1; transform: translate(0, -50%); }
  .cat-cell.active { background: var(--fg); color: var(--bg); }
  .rail-spacer { padding-right: 48px; }
  .rail-fade { position: absolute; right: 108px; top: 0; bottom: 0; width: 48px; pointer-events: none; background: linear-gradient(to right, transparent, var(--bg)); }
  
  .layout-toggle {
    display: flex;
    height: 36px;
    border-left: 0.5px solid var(--rule);
    background: var(--bg);
    position: relative;
    z-index: 2;
  }
  .layout-btn {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    color: var(--muted);
    transition: color 0.15s, background 0.15s;
    font-size: 18px;
    position: relative;
    border-right: 0.5px solid var(--rule);
  }
  .layout-btn:last-child { border-right: none; }
  .layout-btn:hover { color: var(--fg); background: color-mix(in srgb, var(--fg) 4%, transparent); }
  :global([data-layout="list"]) .layout-btn[data-layout-choice="list"],
  :global([data-layout="grid"]) .layout-btn[data-layout-choice="grid"],
  :global([data-layout="poster"]) .layout-btn[data-layout-choice="poster"] {
    background: var(--fg);
    color: var(--bg);
  }

  @media (max-width: 720px) {
    .rail-wrap { top: 64px; }
    .rail-anchor { display: none; }
    .category-rail { scroll-snap-type: x proximity; }
    .cat-cell { scroll-snap-align: start; padding: 0 16px; }
    .rail-fade { display: block; right: 108px; }
  }
</style>

<script>
  const initLayoutToggle = () => {
    const buttons = document.querySelectorAll<HTMLButtonElement>('[data-layout-choice]');
    if (!buttons.length) return;

    const syncState = () => {
      const current = document.documentElement.getAttribute('data-layout') || 'grid';
      buttons.forEach(button => button.setAttribute('aria-pressed', String(button.dataset.layoutChoice === current)));
    };

    buttons.forEach(button => {
      if (button.dataset.initialized === 'true') return;
      button.dataset.initialized = 'true';
      button.addEventListener('click', () => {
        const next = button.dataset.layoutChoice || 'grid';
        const isMobile = window.matchMedia('(max-width: 720px)').matches;
        document.documentElement.setAttribute('data-layout', next);
        localStorage.setItem(isMobile ? 'sinpes-layout-mobile' : 'sinpes-layout-desktop', next);
        syncState();
      });
    });
    syncState();
  };

  initLayoutToggle();
  document.addEventListener('astro:page-load', initLayoutToggle);
</script>
