---
import { languages, defaultLang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
interface Props { locale?: keyof typeof languages; }
const { locale = defaultLang } = Astro.props;
const t = useTranslations(locale);
const basePath = locale === defaultLang ? '/' : `/${locale}/`;
---

<form id="search-form" class="search-container" action={basePath} method="get">
  <input class="search-box" type="search" name="q" placeholder={t('search.placeholder') || 'Search fonts...'} />
</form>

<style>
  .search-container { display: flex; align-items: center; margin: 0; }
  .search-box {
    height: 32px;
    border: 0.5px solid var(--rule);
    background: transparent;
    color: var(--fg);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0 12px;
    width: 180px;
    border-radius: 0;
    font-family: inherit;
    transition: border-color 0.2s, width 0.3s;
  }
  .search-box::placeholder { color: var(--muted); }
  .search-box:focus { outline: none; border-color: var(--fg); width: 220px; }

  /* Remove default webkit search styling */
  .search-box::-webkit-search-decoration,
  .search-box::-webkit-search-cancel-button,
  .search-box::-webkit-search-results-button,
  .search-box::-webkit-search-results-decoration { display: none; }

  @media (max-width: 720px) {
    .search-container { width: 100%; }
    .search-box { width: 100%; height: 44px; font-size: 14px; border-radius: 0; letter-spacing: 0.04em; }
    .search-box:focus { width: 100%; }
  }
</style>

<script>
  const initSearch = () => {
    const searchBoxes = document.querySelectorAll('.search-box');
    const params = new URLSearchParams(window.location.search);
    const initialQuery = params.get('q');
    
    // Targets .font-item — the wrapper used by FontItem.astro.
    // Works from any page, including /blog, because:
    //  - If font items are present (archive pages), it filters inline.
    //  - If no font items exist (e.g. blog), the form submit navigates to the archive.
    function filterItems(query: string) {
      const items = document.querySelectorAll('.font-item');
      items.forEach(item => {
        const text = item.textContent?.toLowerCase() || '';
        (item as HTMLElement).style.display = (!query || text.includes(query)) ? '' : 'none';
      });
    }

    if (initialQuery) {
      searchBoxes.forEach(box => {
        (box as HTMLInputElement).value = initialQuery;
      });
      filterItems(initialQuery.toLowerCase().trim());
    }

    searchBoxes.forEach(box => {
      box.addEventListener('input', (e) => {
        const query = (e.target as HTMLInputElement).value.toLowerCase().trim();
        const hasItems = document.querySelectorAll('.font-item').length > 0;
        if (hasItems) {
          filterItems(query);
        }
        // If not on an archive page, the form submit will navigate to the font archive
      });
    });
  };
  
  initSearch();
  document.addEventListener('astro:page-load', initSearch);
</script>
