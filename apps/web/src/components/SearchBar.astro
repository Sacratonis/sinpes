---
import { languages, defaultLang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
interface Props { locale?: keyof typeof languages; }
const { locale = defaultLang } = Astro.props;
const t = useTranslations(locale);
const basePath = locale === defaultLang ? '/' : `/${locale}/`;
---

<form class="search-container" action={basePath} method="get" data-empty-label={t('search.empty')}>
  <input class="search-box" type="search" name="q" placeholder={t('search.placeholder') || 'Search fonts...'} aria-label={t('search.placeholder')} />
</form>

<style>
  .search-container { display: flex; align-items: center; margin: 0; }
  .search-box {
    height: 32px;
    border: 0.5px solid var(--rule);
    background: transparent;
    color: var(--fg);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0 12px;
    width: 180px;
    border-radius: 0;
    font-family: inherit;
    transition: border-color 0.15s;
  }
  .search-box::placeholder { color: var(--muted); }
  .search-box:focus { outline: none; border-color: var(--fg); }

  /* Remove default webkit search styling */
  .search-box::-webkit-search-decoration,
  .search-box::-webkit-search-cancel-button,
  .search-box::-webkit-search-results-button,
  .search-box::-webkit-search-results-decoration { display: none; }

  @media (max-width: 720px) {
    .search-container { width: 100%; }
    .search-box { width: 100%; height: 44px; font-size: 14px; border-radius: 0; letter-spacing: 0.04em; }
    .search-box:focus { width: 100%; }
  }
</style>

<style is:global>
  .search-empty {
    grid-column: 1 / -1;
    padding: 80px 24px;
    text-align: center;
    color: var(--muted);
    font-size: 14px;
  }
</style>

<script>
  const initSearch = () => {
    const searchBoxes = document.querySelectorAll<HTMLInputElement>('.search-box');
    const searchForms = document.querySelectorAll<HTMLFormElement>('.search-container');
    const params = new URLSearchParams(window.location.search);
    const initialQuery = params.get('q') || '';

    const normalize = (value: string) => value
      .normalize('NFKD')
      .replace(/[\u0300-\u036f]/g, '')
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, ' ')
      .trim();

    function filterItems(query: string) {
      const items = document.querySelectorAll<HTMLElement>('.font-item[data-font-search]');
      const tokens = normalize(query).split(/\s+/).filter(Boolean);
      const indexedItems = [...items].map(item => ({
        item,
        words: normalize(item.dataset.fontSearch || '').split(/\s+/).filter(Boolean),
      }));
      const hasExactResult = tokens.length > 0 && indexedItems.some(({ words }) =>
        tokens.every(token => words.includes(token))
      );
      let visibleCount = 0;
      indexedItems.forEach(({ item, words }) => {
        const matches = tokens.length === 0 || tokens.every(token =>
          hasExactResult ? words.includes(token) : words.some(word => word.startsWith(token))
        );
        item.hidden = !matches;
        if (matches) visibleCount += 1;
      });

      const list = document.querySelector<HTMLElement>('.font-list');
      let empty = list?.querySelector<HTMLElement>('.search-empty');
      if (list && items.length > 0 && tokens.length > 0 && visibleCount === 0) {
        if (!empty) {
          empty = document.createElement('div');
          empty.className = 'search-empty';
          empty.textContent = searchForms[0]?.dataset.emptyLabel || '';
          list.appendChild(empty);
        }
        empty.hidden = false;
      } else if (empty) {
        empty.hidden = true;
      }
      return items.length;
    }

    searchBoxes.forEach(box => { box.value = initialQuery; });
    filterItems(initialQuery);

    searchBoxes.forEach(box => {
      if (box.dataset.initialized === 'true') return;
      box.dataset.initialized = 'true';
      box.addEventListener('input', (e) => {
        const query = (e.target as HTMLInputElement).value;
        searchBoxes.forEach(other => { if (other !== e.target) other.value = query; });
        if (filterItems(query) > 0) {
          const url = new URL(window.location.href);
          if (query.trim()) url.searchParams.set('q', query.trim());
          else url.searchParams.delete('q');
          history.replaceState({}, '', url);
        }
      });
    });

    searchForms.forEach(form => {
      if (form.dataset.initialized === 'true') return;
      form.dataset.initialized = 'true';
      form.addEventListener('submit', (event) => {
        const input = form.querySelector<HTMLInputElement>('.search-box');
        const query = input?.value || '';
        if (document.querySelectorAll('.font-item[data-font-search]').length > 0) {
          event.preventDefault();
          filterItems(query);
        }
      });
    });
  };
  
  initSearch();
  document.addEventListener('astro:page-load', initSearch);
</script>
