---
import { languages, defaultLang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import { sanitizeFontFamily } from '../utils/font';
import { formatTaxonomyLabel } from '../utils/taxonomy';

interface Props {
  index: number;
  locale?: keyof typeof languages;
  font: any;
}

const { index, locale = defaultLang, font } = Astro.props;

const t = useTranslations(locale);
const basePath = locale === defaultLang ? '' : `/${locale}`;

const paddedIndex = String(index).padStart(2, '0');

// The real font family name — used in both @font-face and the specimen style
const fontFamily = sanitizeFontFamily(font.display_name);
const fontSrc = font.woff2_url || '';

// A single glyph that works well at massive scale across all type categories
const massiveGlyph = 'Aa';

// The injected @font-face CSS string — set:html bakes values in at build time
const fontFaceCSS = fontSrc ? `
  @font-face {
    font-family: "${fontFamily}";
    src: url("${fontSrc}") format('woff2');
    font-weight: 100 900;
    font-style: normal;
    font-display: swap;
  }
` : '';
---

<!-- Real @font-face injected at build time for each card -->
{fontFaceCSS && <style set:html={fontFaceCSS} />}

<div class="font-card font-reveal" role="listitem">
  <!-- Stretched link for full card clickability -->
  <a href={`${basePath}/font/${font.slug}`} class="card-link" aria-label={font.display_name}></a>

  <!-- TOP BAR: Meta -->
  <div class="card-top">
    <span class="card-index tabular">{paddedIndex}</span>
    <span class="card-category label-upper">{formatTaxonomyLabel(font.category || '')}</span>
  </div>
  
  <!-- CENTER: Massive Canvas -->
  <div class="card-canvas">
    <div class="massive-specimen" transition:name={`specimen-${font.slug}`} style={`font-family: "${fontFamily}", 'IBM Plex Sans', sans-serif`}>
      {massiveGlyph}
    </div>
  </div>
  
  <!-- BOTTOM: Name and Actions -->
  <div class="card-bottom">
    <span class="card-name" transition:name={`name-${font.slug}`}>
      {font.display_name}
      {font.is_demo && <span class="card-dot" title="Demo version"></span>}
    </span>
    
    <div class="card-actions">
      <a href={`${basePath}/test/${font.slug}`} class="card-action-btn test-btn" aria-label={`Test ${font.display_name}`}>
        {t('row.test')}
        <span class="btn-arrow-wrap right-wrap">
          <span class="arrow-right">&rarr;</span>
          <span class="arrow-right clone">&rarr;</span>
        </span>
      </a>
      <a href={`${basePath}/font/${font.slug}`} class="card-action-btn primary dl-btn" aria-label={`Download ${font.display_name}`}>
        {t('row.get')}
        <span class="btn-arrow-wrap">
          <span class="arrow-down">&darr;</span>
          <span class="arrow-down clone">&darr;</span>
        </span>
      </a>
    </div>
  </div>
</div>

<style>
  .font-card {
    position: relative;
    display: flex;
    flex-direction: column;
    border-right: 0.5px solid var(--rule);
    border-bottom: 0.5px solid var(--rule);
    background: var(--bg);
    aspect-ratio: 4 / 5; /* Forces a tall, poster-like proportion */
    min-height: 480px;
    transition: background 0.2s;
    cursor: pointer;
  }
  .font-card:hover:not(:has(.card-action-btn:hover)) {
    background: color-mix(in srgb, var(--fg) 2%, transparent);
  }
  .font-reveal {
    opacity: 1;
    transform: translateY(0);
  }

  .card-link {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  /* TOP BAR */
  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 24px;
    border-bottom: 0.5px solid var(--rule);
    font-size: 11px;
    color: var(--muted);
  }
  .card-index {
    font-weight: 500;
  }
  .label-upper {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }

  /* CANVAS */
  .card-canvas {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden; /* Crucial for bleed */
  }
  .massive-specimen {
    font-size: clamp(200px, 20vw, 320px);
    line-height: 0.75;
    letter-spacing: -0.06em;
    color: var(--fg);
    user-select: none;
    white-space: nowrap;
    text-overflow: clip;
    /* Move slightly to create an intentional bleed off the bottom/right edges */
    transform: translate(10%, 15%); 
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), color 0.3s;
  }
  .font-card:hover:not(:has(.card-action-btn:hover)) .massive-specimen {
    transform: translate(8%, 13%) scale(1.05);
    color: var(--muted);
  }
  /* BOTTOM */
  .card-bottom {
    display: flex;
    flex-direction: column;
    border-top: 0.5px solid var(--rule);
    position: relative;
    z-index: 2; /* Sits above the stretched link so buttons are clickable */
  }
  
  .card-name {
    font-size: 32px;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--fg);
    padding: 24px;
    display: flex;
    align-items: center;
    gap: 12px;
    border-bottom: 0.5px solid var(--rule);
  }
  .card-dot {
    width: 6px;
    height: 6px;
    background: var(--fg);
    border-radius: 50%;
  }

  .card-actions {
    display: flex;
    height: 48px;
  }
  .card-action-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 20px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--fg);
    text-decoration: none;
    position: relative;
    overflow: hidden;
    z-index: 1;
    transition: color 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    min-width: 0;
  }
  .card-action-btn:first-child { border-right: 0.5px solid var(--rule); }

  /* Swipe-fill for Test button */
  .test-btn { background: transparent; }
  .test-btn::before {
    content: ""; position: absolute; inset: 0; background: var(--fg); z-index: -1;
    transform: scaleX(0); transform-origin: right;
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .test-btn:hover { color: var(--bg); }
  .test-btn:hover::before { transform: scaleX(1); transform-origin: left; }

  /* Swipe-fill for Download button */
  .dl-btn { background: transparent; color: var(--bg); }
  .dl-btn::before {
    content: ""; position: absolute; inset: 0; background: var(--fg); z-index: -1;
    transform: scaleX(1); transform-origin: right;
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .dl-btn:hover { color: var(--fg); }
  .dl-btn:hover::before { transform: scaleX(0); transform-origin: left; }

  /* Marquee Arrows */
  .btn-arrow-wrap {
    position: relative;
    display: inline-flex;
    flex-direction: column;
    overflow: hidden;
    height: 16px;
  }
  .btn-arrow-wrap.right-wrap {
    flex-direction: row;
    width: 16px;
    height: auto;
  }
  .arrow-down, .arrow-right {
    font-size: 16px;
    font-weight: 400;
    line-height: 1;
    display: block;
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .arrow-down.clone { position: absolute; top: -100%; left: 0; }
  .arrow-right.clone { position: absolute; top: 0; left: -100%; }

  .test-btn:hover .arrow-right { transform: translateX(100%); }
  .dl-btn:hover .arrow-down { transform: translateY(100%); }

  @media (max-width: 720px) {
    .font-card { min-height: 440px; aspect-ratio: auto; }
    .card-name {
      min-width: 0;
      padding: 20px;
      font-size: clamp(22px, 8vw, 30px);
      line-height: 1.08;
      overflow-wrap: anywhere;
    }
    .card-actions { width: 100%; }
    .card-action-btn { display: flex; padding: 0 16px; }
    .massive-specimen { font-size: clamp(150px, 52vw, 220px); transform: none; }
  }
</style>
