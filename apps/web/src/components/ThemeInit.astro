---
// strictly an inline script for the <head>
---
<script is:inline>
  const setTheme = () => {
    const theme = (() => {
      if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
        return localStorage.getItem('theme');
      }
      if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
        return 'dark';
      }
      return 'light';
    })();
    
    if (theme === 'light') {
      document.documentElement.setAttribute('data-theme', 'light');
    } else {
      document.documentElement.setAttribute('data-theme', 'dark');
    }
    window.localStorage.setItem('theme', theme);
  };

  const validLayouts = ['list', 'grid', 'poster'];
  const mobileLayoutQuery = window.matchMedia('(max-width: 720px)');

  const setLayout = () => {
    const isMobile = mobileLayoutQuery.matches;
    const key = isMobile ? 'sinpes-layout-mobile' : 'sinpes-layout-desktop';
    let layout = localStorage.getItem(key);

    if (!validLayouts.includes(layout)) {
      const legacy = isMobile ? null : localStorage.getItem('sinpes-layout');
      layout = validLayouts.includes(legacy) ? legacy : (isMobile ? 'list' : 'grid');
      localStorage.setItem(key, layout);
    }

    document.documentElement.setAttribute('data-layout', layout);
    document.documentElement.setAttribute('data-layout-context', isMobile ? 'mobile' : 'desktop');
  };
  
  setTheme();
  setLayout();
  mobileLayoutQuery.addEventListener('change', setLayout);
  
  document.addEventListener('astro:after-swap', () => {
    setTheme();
    setLayout();
  });
</script>
