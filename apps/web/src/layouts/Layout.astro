---
import { ViewTransitions } from 'astro:transitions';
import ThemeInit from '../components/ThemeInit.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import '../styles/global.css';

import { languages, defaultLang } from '../i18n/ui';
import { generateCanonical, generateHreflang } from '../lib/seo';

interface Props {
  title: string;
  description: string;
  locale?: keyof typeof languages; 
  image?: string;
  imageAlt?: string;
  imageWidth?: number;
  imageHeight?: number;
  ogType?: 'website' | 'article';
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleSection?: string;
  articleAuthorUrl?: string;
  availableLocales?: Array<keyof typeof languages>;
  robots?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  locale = defaultLang,
  image,
  imageAlt,
  imageWidth,
  imageHeight,
  ogType = 'website',
  articlePublishedTime,
  articleModifiedTime,
  articleSection,
  articleAuthorUrl,
  availableLocales,
  robots = 'index,follow,max-image-preview:large',
  structuredData,
} = Astro.props;

const siteURL = Astro.site || new URL('https://sinpes.com');
const currentPath = Astro.url.pathname;
const canonicalURL = generateCanonical(siteURL, currentPath);
const hreflangLinks = generateHreflang(
  siteURL,
  currentPath,
  locale as keyof typeof languages,
  availableLocales
);
const socialImage = image ? new URL(image, siteURL).href : undefined;
const openGraphLocales: Record<keyof typeof languages, string> = {
  en: 'en_US',
  es: 'es_ES',
  pt: 'pt_PT',
};
const serializedStructuredData = structuredData
  ? JSON.stringify(structuredData).replace(/</g, '\\u003c')
  : '';
---
<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="SINPES" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content={openGraphLocales[locale]} />
    {availableLocales
      ?.filter((availableLocale) => availableLocale !== locale)
      .map((availableLocale) => (
        <meta property="og:locale:alternate" content={openGraphLocales[availableLocale]} />
      ))}
    {socialImage && <meta property="og:image" content={socialImage} />}
    {socialImage && imageAlt && <meta property="og:image:alt" content={imageAlt} />}
    {socialImage && imageWidth && <meta property="og:image:width" content={String(imageWidth)} />}
    {socialImage && imageHeight && <meta property="og:image:height" content={String(imageHeight)} />}
    {ogType === 'article' && articlePublishedTime && (
      <meta property="article:published_time" content={articlePublishedTime} />
    )}
    {ogType === 'article' && articleModifiedTime && (
      <meta property="article:modified_time" content={articleModifiedTime} />
    )}
    {ogType === 'article' && articleSection && (
      <meta property="article:section" content={articleSection} />
    )}
    {ogType === 'article' && articleAuthorUrl && (
      <meta property="article:author" content={articleAuthorUrl} />
    )}
    <meta name="twitter:card" content={socialImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {socialImage && <meta name="twitter:image" content={socialImage} />}
    {socialImage && imageAlt && <meta name="twitter:image:alt" content={imageAlt} />}
    <meta name="msvalidate.01" content="451E1BD0AE8253F7665FC14EBC0D57B6" />
    <meta name="google-site-verification" content="j52WC1RMWVBHpZXbLJeGd5SfNWlBqcTgkm74RGMvJYQ" />
    
    <link rel="canonical" href={canonicalURL} />
    <ViewTransitions />
    {Object.entries(hreflangLinks).map(([lang, url]) => (
      <link rel="alternate" hreflang={lang} href={url} />
    ))}
    {serializedStructuredData && (
      <script type="application/ld+json" set:html={serializedStructuredData}></script>
    )}

    <!-- Favicon Activation -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
    
    <!-- Defer ads until consent is granted -->
    <script is:inline>
      window.adsbygoogle = window.adsbygoogle || [];
      window.adsbygoogle.pauseAdRequests = 1;
    </script>
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5794892225491354" crossorigin="anonymous"></script>
    
    <ThemeInit />
  </head>
  <body>
    <Navbar locale={locale} />
    <slot />
    <Footer locale={locale} />
    <CookieConsent locale={locale} />
  </body>
</html>
