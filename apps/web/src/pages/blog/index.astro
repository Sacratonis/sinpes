---
import Layout from '../../layouts/Layout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { blogPosts } from '../../data/blog';
import { defaultLang } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';
import { hasCompleteBlogLocale } from '../../lib/blogLocale.mjs';

const t = useTranslations(defaultLang);
const localizedPosts = blogPosts.filter(post => hasCompleteBlogLocale(post, defaultLang));
---

<Layout 
  title={t('blog.title')}
  description={t('blog.description')}
  locale={defaultLang}
>
  <header class="view-container blog-header">
    <h1>{t('blog.heading')}</h1>
    <p>{t('blog.description')}</p>
  </header>
  <main class="view-container blog-grid">
    {localizedPosts.length > 0 ? localizedPosts.map(post => (
      <BlogCard title={post.title.en} excerpt={post.excerpt.en} date={post.date} slug={post.slug} locale={defaultLang} />
    )) : <div class="empty-state">{t('blog.empty')}</div>}
  </main>
</Layout>

<style>
  .view-container {
    max-width: 1180px;
    margin: 0 auto;
    border-left: 0.5px solid var(--rule);
    border-right: 0.5px solid var(--rule);
  }
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 340px), 1fr));
  }
  .blog-header { padding: 48px 32px; border-bottom: 0.5px solid var(--rule); }
  .blog-header h1 { margin: 0 0 12px; font-size: clamp(32px, 5vw, 64px); font-weight: 500; }
  .blog-header p { margin: 0; max-width: 680px; color: var(--muted); line-height: 1.6; }
  .empty-state { grid-column: 1 / -1; padding: 80px 24px; text-align: center; color: var(--muted); font-size: 14px; }
</style>
