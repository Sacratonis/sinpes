---
import Layout from '../../layouts/Layout.astro';
import CategoryRail from '../../components/CategoryRail.astro';
import PreviewBar from '../../components/PreviewBar.astro';
import FontItem from '../../components/FontItem.astro';
import { loadFontRegistry } from '../../content/fonts/loader';
import { defaultLang } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';
import { categorySlug, uniqueCategoryLabels } from '../../utils/taxonomy';

export async function getStaticPaths() {
  const fonts = await loadFontRegistry();
  const categories = uniqueCategoryLabels(fonts.map(font => font.category));
  return categories.map(categoryName => ({
    params: { slug: categorySlug(categoryName) },
    props: {
      categoryName,
      categories,
      filteredFonts: fonts.filter(font => categorySlug(font.category) === categorySlug(categoryName)),
    }
  }));
}

const { slug } = Astro.params;
const { categoryName, categories, filteredFonts } = Astro.props;
const t = useTranslations(defaultLang);
const title = t('category.title').replace('{category}', categoryName);
const description = t('category.description').replace('{category}', categoryName);
const heading = title.replace(/\s+—\s+SINPES$/i, '');
const pageUrl = new URL(`/category/${slug}/`, Astro.site || 'https://sinpes.com').href;
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      name: heading,
      description,
      url: pageUrl,
      inLanguage: defaultLang,
      mainEntity: { '@type': 'ItemList', numberOfItems: filteredFonts.length },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: t('nav.library'), item: new URL('/', Astro.site || 'https://sinpes.com').href },
        { '@type': 'ListItem', position: 2, name: heading, item: pageUrl },
      ],
    },
  ],
};
---

<Layout 
  title={title}
  description={description}
  locale={defaultLang}
  structuredData={structuredData}
>
  <CategoryRail locale={defaultLang} activeCategory={slug} categories={categories} />
  <header class="category-intro view-container">
    <h1>{heading}</h1>
    <span class="tabular">{t('category.fontCount').replace('{count}', String(filteredFonts.length))}</span>
  </header>
  <PreviewBar locale={defaultLang} />
  
  <main class="view-container">
    <div class="font-list" id="feed" role="list">
      {filteredFonts.length > 0 ? (
        filteredFonts.map((font, index) => (
          <FontItem index={index + 1} font={font} locale={defaultLang} />
        ))
      ) : (
        <div class="empty-state label-upper">{t('category.empty')}</div>
      )}
    </div>
  </main>
</Layout>

<style>
  .category-intro {
    min-height: 72px;
    padding: 16px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    border-bottom: 0.5px solid var(--rule);
  }
  .category-intro h1 { font-size: clamp(20px, 3vw, 32px); font-weight: 500; letter-spacing: -0.02em; }
  .category-intro span { color: var(--muted); font-size: 11px; white-space: nowrap; }
  .font-list {
    width: 100%;
  }

  /* Grid Layout Styles */
  :global([data-layout="grid"]) .font-list,
  :global([data-layout="poster"]) .font-list {
    display: grid;
    border-left: 0.5px solid var(--rule);
    border-top: 0.5px solid var(--rule);
  }
  :global([data-layout="grid"]) .font-list { grid-template-columns: repeat(auto-fill, minmax(min(100%, 250px), 1fr)); }
  :global([data-layout="poster"]) .font-list { grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr)); }

  /* List Layout Styles */
  :global([data-layout="list"]) .font-list {
    display: block;
  }

  .empty-state {
    padding: 80px 24px;
    text-align: center;
    color: var(--muted);
    font-size: 14px;
  }
  @media (max-width: 720px) {
    .category-intro { min-height: 64px; padding: 14px 16px; }
  }
</style>
