---
import Layout from '../../layouts/Layout.astro';
import { languages, defaultLang } from '../../i18n/ui';

export async function getStaticPaths() {
  const locales = Object.keys(languages).filter(l => l !== defaultLang);
  return locales.map(l => ({ params: { lang: l } }));
}

const { lang } = Astro.params;
const locale = lang as keyof typeof languages;

const content = {
  es: {
    title: "Aviso Legal | Sinpes",
    meta: "Consulta el aviso legal de SINPES sobre disponibilidad de fuentes, propiedad intelectual de terceros, enlaces externos, garantías y responsabilidad.",
    h1: "Aviso Legal",
    lastUpdated: "Última Actualización: Julio de 2026",
    p1: "La información y los activos digitales proporcionados por Sinpes son para fines informativos, de archivo, previsualización y diseño. No hacemos declaraciones ni garantías de ningún tipo sobre la integridad, precisión, confiabilidad, derechos de uso o idoneidad de la tipografía alojada en nuestra plataforma.",
    h2_1: "1. Provisión \"Tal Cual\"",
    p2: "Todas las tipografías y el software relacionado se proporcionan \"TAL CUAL\" y \"SEGÚN DISPONIBILIDAD\". Sinpes renuncia expresamente a todas las garantías, ya sean expresas o implícitas, incluidas, entre otras, las garantías implícitas de comerciabilidad, idoneidad para un propósito particular y no infracción.",
    h2_2: "2. Limitación de Responsabilidad",
    p3: "En ningún caso Sinpes, sus fundadores o afiliados serán responsables de ningún daño directo, indirecto, incidental, consecuente o punitivo que surja de su acceso o uso de las fuentes descargadas de nuestro archivo. Esto incluye, sin limitación, daños por pérdida de ganancias, interrupción del negocio o pérdida de datos, incluso si se nos ha advertido de la posibilidad de tales daños.",
    h2_3: "3. Propiedad Intelectual de Terceros",
    p4: "Sinpes aloja e indexa archivos de fuentes creados por diseñadores, fundiciones y proyectos de terceros. No reclamamos propiedad sobre estos activos y no otorgamos derechos comerciales ni permiso legal para ningún uso específico. Es responsabilidad del usuario final decidir cómo utiliza cada fuente y revisar cualquier información de licencia de la fuente original o incluida con la descarga cuando esté disponible. Sinpes no asume responsabilidad por disputas legales derivadas del uso de fuentes por parte de nuestros usuarios.",
    h2_4: "4. Enlaces Externos",
    p5: "Nuestra plataforma puede contener enlaces a fundiciones externas o sitios web de terceros. Sinpes no tiene control sobre el contenido o las prácticas de estos sitios externos y no asume ninguna responsabilidad por sus operaciones o políticas de privacidad."
  },
  pt: {
    title: "Aviso Legal | Sinpes",
    meta: "Consulte o aviso legal da SINPES sobre disponibilidade de fontes, propriedade intelectual de terceiros, links externos, garantias e responsabilidade.",
    h1: "Aviso Legal",
    lastUpdated: "Última Atualização: Julho de 2026",
    p1: "As informações e ativos digitais fornecidos pela Sinpes são para fins informativos, de arquivo, pré-visualização e design. Não fazemos declarações ou garantias de qualquer tipo sobre a integridade, precisão, confiabilidade, direitos de uso ou adequação da tipografia hospedada em nossa plataforma.",
    h2_1: "1. Provisão \"No Estado em que se Encontra\"",
    p2: "Todas as tipografias e softwares relacionados são fornecidos \"NO ESTADO EM QUE SE ENCONTRAM\" e \"CONFORME DISPONÍVEIS\". A Sinpes isenta-se expressamente de todas as garantias, sejam expressas ou implícitas, incluindo, entre outras, as garantias implícitas de comercialização, adequação a um fim específico e não violação.",
    h2_2: "2. Limitação de Responsabilidade",
    p3: "Em nenhum caso a Sinpes, seus fundadores ou afiliados serão responsabilizados por quaisquer danos diretos, indiretos, incidentais, consequenciais ou punitivos decorrentes do seu acesso ou uso das fontes baixadas de nosso arquivo. Isso inclui, sem limitação, danos por perda de lucros, interrupção de negócios ou perda de dados, mesmo que tenhamos sido avisados da possibilidade de tais danos.",
    h2_3: "3. Propriedade Intelectual de Terceiros",
    p4: "A Sinpes hospeda e indexa arquivos de fontes criados por designers, fundições e projetos de terceiros. Não reivindicamos propriedade sobre esses ativos e não concedemos direitos comerciais nem permissão legal para qualquer uso específico. É responsabilidade do usuário final decidir como cada fonte será usada e revisar qualquer informação de licença da fonte original ou incluída no download quando disponível. A Sinpes não assume responsabilidade por disputas legais decorrentes do uso de fontes por nossos usuários.",
    h2_4: "4. Links Externos",
    p5: "Nossa plataforma pode conter links para fundições externas ou sites de terceiros. A Sinpes não tem controle sobre o conteúdo ou práticas desses sites externos e não assume nenhuma responsabilidade por suas operações ou políticas de privacidade."
  }
};
const c = content[locale as keyof typeof content] || content['es'];
---
<Layout title={c.title} description={c.meta} locale={locale}>
  <main class="view-container legal-page">
    <h1>{c.h1}</h1>
    <p class="last-updated">{c.lastUpdated}</p>
    
    <p>{c.p1}</p>
    
    <h2>{c.h2_1}</h2>
    <p>{c.p2}</p>
    
    <h2>{c.h2_2}</h2>
    <p>{c.p3}</p>
    
    <h2>{c.h2_3}</h2>
    <p>{c.p4}</p>

    <h2>{c.h2_4}</h2>
    <p>{c.p5}</p>
  </main>
</Layout>

<style>
  .legal-page { padding: 80px 24px; max-width: 800px; margin: 0 auto; border-left: 0.5px solid var(--rule); border-right: 0.5px solid var(--rule); min-height: 60vh; }
  h1 { font-size: 48px; margin-bottom: 32px; letter-spacing: -0.02em; font-weight: 500; }
  h2 { font-size: 12px; margin-top: 48px; margin-bottom: 16px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); font-weight: 600; }
  p { font-size: 16px; line-height: 1.7; margin-bottom: 24px; color: var(--fg); max-width: 700px; }
  .last-updated { font-size: 14px; color: var(--muted); margin-bottom: 48px; font-family: 'IBM Plex Mono', monospace; font-variant-numeric: tabular-nums; }
</style>
