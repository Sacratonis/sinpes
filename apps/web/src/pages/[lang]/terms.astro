---
import Layout from '../../layouts/Layout.astro';
import { languages, defaultLang } from '../../i18n/ui';

export async function getStaticPaths() {
  const locales = Object.keys(languages).filter(l => l !== defaultLang);
  return locales.map(l => ({ params: { lang: l } }));
}

const { lang } = Astro.params;
const locale = lang as keyof typeof languages;

const content = {
  es: {
    title: "Términos de Servicio | Sinpes",
    h1: "Términos de Servicio",
    lastUpdated: "Última Actualización: Julio de 2026",
    p1: "Bienvenido a Sinpes. Al acceder, navegar o utilizar nuestro archivo de tipografía digital, usted acepta estar sujeto a estos Términos de Servicio. Por favor revise estos términos cuidadosamente, ya que rigen su relación con nuestra plataforma.",
    h2_1: "1. Aceptación de los Términos",
    p2: "Su acceso y uso de Sinpes está condicionado a su aceptación y cumplimiento de estos Términos. Si no está de acuerdo con alguna parte de los términos, no podrá acceder al servicio.",
    h2_2: "2. Propiedad Intelectual y Licencias de Fuentes",
    p3: "Sinpes opera como un distribuidor de tipografías de código abierto. Las fuentes alojadas en nuestra plataforma siguen siendo propiedad intelectual de sus respectivos creadores y fundiciones. Cada tipografía se rige por su licencia de código abierto específica (como la SIL Open Font License o Apache 2.0). Aunque es libre de descargar y usar estas fuentes comercialmente según lo permitan sus licencias, usted es el único responsable de asegurar que su uso cumpla con los términos de licencia adjuntos.",
    h2_3: "3. Contenido del Sitio y Derechos de Autor",
    p4: "Aunque las fuentes son de código abierto, el diseño patentado, la arquitectura, el código base, el texto y la identidad visual de la plataforma Sinpes están protegidos por leyes de derechos de autor y propiedad intelectual. Queda estrictamente prohibida la reproducción no autorizada o la extracción (scraping) de la interfaz patentada de nuestra plataforma.",
    h2_4: "4. Política de Uso Aceptable",
    p5: "Usted acepta no utilizar nuestra infraestructura con fines maliciosos, lo que incluye, entre otros, ejecutar ataques de denegación de servicio (DoS), extracción automatizada que eluda nuestros límites de API o cualquier actividad que comprometa la integridad y el rendimiento de nuestros servidores.",
    h2_5: "5. Modificaciones al Servicio",
    p6: "Sinpes se reserva el derecho de modificar, suspender o interrumpir cualquier aspecto del servicio en cualquier momento, con o sin previo aviso. No seremos responsables ante usted ni ante terceros por ninguna modificación o interrupción del servicio."
  },
  pt: {
    title: "Termos de Serviço | Sinpes",
    h1: "Termos de Serviço",
    lastUpdated: "Última Atualização: Julho de 2026",
    p1: "Bem-vindo à Sinpes. Ao acessar, navegar ou usar nosso arquivo de tipografia digital, você concorda em se submeter a estes Termos de Serviço. Por favor, reveja estes termos com cuidado, pois eles regem o seu relacionamento com a nossa plataforma.",
    h2_1: "1. Aceitação dos Termos",
    p2: "Seu acesso e uso da Sinpes estão condicionados à sua aceitação e conformidade com estes Termos. Se você discordar de qualquer parte dos termos, não poderá acessar o serviço.",
    h2_2: "2. Propriedade Intelectual e Licenças de Fontes",
    p3: "A Sinpes opera como distribuidora de tipografias de código aberto. As fontes hospedadas em nossa plataforma permanecem propriedade intelectual de seus respectivos criadores e fundições. Cada tipografia é regida por sua licença específica de código aberto (como a Licença de Fonte Aberta SIL ou Apache 2.0). Embora você esteja livre para baixar e usar essas fontes comercialmente conforme permitido por suas licenças, você é o único responsável por garantir que seu uso esteja em conformidade com os termos de licença em anexo.",
    h2_3: "3. Conteúdo do Site e Direitos Autorais",
    p4: "Embora as fontes sejam de código aberto, o design proprietário, a arquitetura, a base de código, o texto e a identidade visual da própria plataforma Sinpes são protegidos por leis de direitos autorais e de propriedade intelectual. A reprodução não autorizada ou a raspagem (scraping) da interface proprietária de nossa plataforma é estritamente proibida.",
    h2_4: "4. Política de Uso Aceitável",
    p5: "Você concorda em não usar nossa infraestrutura para fins maliciosos, incluindo, entre outros, ataques de negação de serviço (DoS), raspagem automatizada que burle nossos limites de API ou qualquer atividade que comprometa a integridade e o desempenho de nossos servidores.",
    h2_5: "5. Modificações no Serviço",
    p6: "A Sinpes reserva-se o direito de modificar, suspender ou descontinuar qualquer aspecto do serviço a qualquer momento, com ou sem aviso prévio. Não seremos responsáveis perante você ou qualquer terceiro por qualquer modificação ou interrupção do serviço."
  }
};
const c = content[locale as keyof typeof content] || content['es'];
---
<Layout title={c.title} description={c.p1} locale={locale}>
  <main class="view-container legal-page">
    <h1>{c.h1}</h1>
    <p class="last-updated">{c.lastUpdated}</p>
    
    <p>{c.p1}</p>
    
    <h2>{c.h2_1}</h2>
    <p>{c.p2}</p>
    
    <h2>{c.h2_2}</h2>
    <p>{c.p3}</p>
    
    <h2>{c.h2_3}</h2>
    <p>{c.p4}</p>

    <h2>{c.h2_4}</h2>
    <p>{c.p5}</p>

    <h2>{c.h2_5}</h2>
    <p>{c.p6}</p>
  </main>
</Layout>

<style>
  .legal-page { padding: 80px 24px; max-width: 800px; margin: 0 auto; border-left: 0.5px solid var(--rule); border-right: 0.5px solid var(--rule); min-height: 60vh; }
  h1 { font-size: 48px; margin-bottom: 32px; letter-spacing: -0.02em; font-weight: 500; }
  h2 { font-size: 12px; margin-top: 48px; margin-bottom: 16px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); font-weight: 600; }
  p { font-size: 16px; line-height: 1.7; margin-bottom: 24px; color: var(--fg); max-width: 700px; }
  .last-updated { font-size: 14px; color: var(--muted); margin-bottom: 48px; font-family: 'IBM Plex Mono', monospace; font-variant-numeric: tabular-nums; }
</style>
