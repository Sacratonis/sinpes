---
import Layout from '../../layouts/Layout.astro';
import { languages, defaultLang } from '../../i18n/ui';

export async function getStaticPaths() {
  const locales = Object.keys(languages).filter(l => l !== defaultLang);
  return locales.map(l => ({ params: { lang: l } }));
}

const { lang } = Astro.params;
const locale = lang as keyof typeof languages;

const content = {
  es: {
    title: "Sobre el Archivo | Sinpes",
    meta: "Conoce cómo SINPES selecciona y distribuye familias tipográficas gratuitas para diseñadores, desarrolladores, sitios web, aplicaciones e impresión.",
    h1: "Sobre Sinpes",
    p1: "Sinpes es un archivo enfocado en familias tipográficas gratuitas. El proyecto existe para facilitar el descubrimiento, la prueba, la vista previa y la descarga de fuentes para trabajos reales de diseño en sitios web, aplicaciones, piezas editoriales, marcas e impresión.",
    h2_1: "Nuestros Estándares de Curaduría",
    p2: "Cada familia añadida al archivo pasa por comprobaciones automatizadas de integridad de archivos, agrupación familiar, formatos web utilizables, calidad de metadatos y renderizado de vista previa. Cuando aparece un problema, la fuente queda fuera del archivo público hasta que el flujo pueda procesarla correctamente.",
    h2_2: "Fuentes Gratis para Todos",
    p3: "Sinpes se basa en una idea simple: la buena tipografía debe ser fácil de acceder. Priorizamos familias tipográficas gratuitas y una presentación clara para que los diseñadores puedan evaluar cada fuente rápidamente antes de descargarla.",
    h2_3: "Infraestructura Técnica",
    p4: "El flujo de distribución convierte las familias subidas en recursos WOFF2 optimizados para vistas previas rápidas, conservando los archivos fuente descargables para quienes necesitan los formatos originales. Los metadatos, imágenes, datos de búsqueda y snapshots estáticos se generan como parte del proceso de publicación."
  },
  pt: {
    title: "Sobre o Arquivo | Sinpes",
    meta: "Conheça como a SINPES seleciona e distribui famílias tipográficas gratuitas para designers, desenvolvedores, sites, aplicativos e impressão.",
    h1: "Sobre a Sinpes",
    p1: "A Sinpes é um arquivo focado em famílias tipográficas gratuitas. O projeto existe para facilitar a descoberta, a visualização, o teste e o download de fontes para trabalhos reais de design em sites, aplicativos, editoriais, marcas e impressão.",
    h2_1: "Nossos Padrões de Curadoria",
    p2: "Cada família adicionada ao arquivo passa por verificações automatizadas de integridade dos arquivos, agrupamento familiar, formatos web utilizáveis, qualidade dos metadados e renderização de prévia. Quando um problema é encontrado, a fonte fica fora do arquivo público até que o fluxo consiga processá-la corretamente.",
    h2_2: "Fontes Grátis para Todos",
    p3: "A Sinpes é construída em torno de uma ideia simples: boa tipografia deve ser fácil de acessar. Priorizamos famílias tipográficas gratuitas e uma apresentação clara para que designers possam avaliar cada fonte rapidamente antes de baixá-la.",
    h2_3: "Infraestrutura Técnica",
    p4: "O fluxo de distribuição converte famílias enviadas em recursos WOFF2 otimizados para prévias rápidas, preservando os arquivos fonte para usuários que precisam dos formatos originais. Metadados, imagens, dados de busca e snapshots estáticos são gerados como parte do processo de publicação."
  }
};
const c = content[locale as keyof typeof content] || content['es'];
---
<Layout title={c.title} description={c.meta} locale={locale}>
  <main class="view-container legal-page">
    <h1>{c.h1}</h1>
    <p>{c.p1}</p>
    
    <h2>{c.h2_1}</h2>
    <p>{c.p2}</p>
    
    <h2>{c.h2_2}</h2>
    <p>{c.p3}</p>
    
    <h2>{c.h2_3}</h2>
    <p>{c.p4}</p>
  </main>
</Layout>

<style>
  .legal-page { padding: 80px 24px; max-width: 800px; margin: 0 auto; border-left: 0.5px solid var(--rule); border-right: 0.5px solid var(--rule); min-height: 60vh; }
  h1 { font-size: 48px; margin-bottom: 32px; letter-spacing: -0.02em; font-weight: 500; }
  h2 { font-size: 12px; margin-top: 48px; margin-bottom: 16px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); font-weight: 600; }
  p { font-size: 16px; line-height: 1.7; margin-bottom: 24px; color: var(--fg); max-width: 700px; }
  .last-updated { font-size: 14px; color: var(--muted); margin-bottom: 48px; font-family: 'IBM Plex Mono', monospace; font-variant-numeric: tabular-nums; }
</style>
