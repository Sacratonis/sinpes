---
import Layout from "../layouts/Layout.astro";
import FontItem from "../components/FontItem.astro";
import CategoryRail from "../components/CategoryRail.astro";
import PreviewBar from "../components/PreviewBar.astro";
import { loadFontRegistry } from "../content/fonts/loader";
import { defaultLang } from "../i18n/ui";
import { useTranslations } from "../i18n/utils";

const fonts = await loadFontRegistry();
const t = useTranslations(defaultLang);

// 🌟 DYNAMIC CATEGORIES: Extracts only the categories that actually exist in the DB
const uniqueCategories = [...new Set(fonts.map((f) => f.category))].filter(
  Boolean,
);
---

<Layout
  title={t("home.title")}
  description={t("home.description")}
  locale={defaultLang}
>
  <CategoryRail locale={defaultLang} categories={uniqueCategories} />
  <PreviewBar locale={defaultLang} />

  <main class="view-container">
    <div class="font-list" role="list">
      {
        fonts.length > 0 ? (
          fonts.map((font, index) => (
            <FontItem font={font} index={index + 1} locale={defaultLang} />
          ))
        ) : (
          <div class="empty-state">
            <p>{t("home.empty")}</p>
          </div>
        )
      }
    </div>
  </main>
</Layout>

<style>
  .font-list { 
    width: 100%; 
  }
  
  /* Grid Layout Styles */
  :global([data-layout="grid"]) .font-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr));
    border-left: 0.5px solid var(--rule);
    border-top: 0.5px solid var(--rule);
  }

  /* List Layout Styles */
  :global([data-layout="list"]) .font-list {
    display: block;
  }
  
  .empty-state {
    padding: 80px 24px;
    text-align: center;
    color: var(--muted);
    font-size: 14px;
  }
</style>
