# ==========================================
# SINPES V1 — Environment Variables Template
# ==========================================

# --- Telegram: Font / Oracle Bot ---------------
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_MAIN_CHANNEL_ID=
TELEGRAM_ORACLE_BOT_TOKEN=

# --- Telegram: Writing SEO Bot (new, separate) --
TELEGRAM_WRITER_BOT_TOKEN=
TELEGRAM_WRITER_REVIEW_CHANNEL_ID=

# --- Gemini: two separate GCP projects ----------
# from Google Cloud project "sinpes-oracle"
GEMINI_ORACLE_MODEL=gemini-flash-latest
ORACLE_GEMINI_ENRICHMENT=true
GEMINI_ORACLE_API_KEY=

# --- Oracle keyword data sources -----------------
PINTEREST_ACCESS_TOKEN=
PINTEREST_REGIONS=US,GB,CA
BING_WEBMASTER_API_KEY=
YANDEX_WORDSTAT_TOKEN=
ORACLE_SCRAPE_START_HOUR_UTC=21
ORACLE_BRIEFING_HOUR_UTC=10
# from Google Cloud project "sinpes-writer"
GEMINI_WRITER_API_KEY=

# --- Cloudflare R2 Storage -----------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

# --- Cloudflare Pages Integration ----------------
CF_PAGES_DEPLOY_HOOK_URL=

# --- Cloudflare Workers AI (image gen) -----------
# Provided via the custom Cloudflare Worker deployed locally. 
# If left blank, the system falls back to Pollinations.
IMAGE_GEN_WORKER_URL=
IMAGE_GEN_WORKER_SECRET=

# --- Image gen fallback ---------------------------
POLLINATIONS_API_KEY=

# --- Security & Access ------------------------------
BUILD_SECRET=
WEBHOOK_ALLOWED_IPS=

# --- Ingestion Pipeline Cadence ----------------------
QUEUE_INTERVAL_MINUTES=30
ARTICLE_QUEUE_INTERVAL_MINUTES=720

# --- Database & System Pathing -----------------------
DATABASE_PATH=/opt/sinpes/data/sinpes.db
SITE_URL=https://sinpes.com
